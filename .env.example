# Copy to .env and fill in. Do NOT commit .env or the service-account key.

FIREBASE_PROJECT_ID=your-gcp-project-id
FIRESTORE_COLLECTION=referral-extraction
FIRESTORE_DATABASE=referral-extraction

# Service account key file (resolved relative to this folder or the project root).
FIREBASE_SERVICE_ACCOUNT_PATH=google.json
# Or paste the SA JSON inline instead of a file:
# FIREBASE_SA_JSON={...}

# Output file (relative paths are written inside this folder).
EXPORT_OUTPUT_PATH=firestore_export.json
