# Copy to .env and fill in. Do NOT commit .env or the service-account key.

FIREBASE_PROJECT_ID=your-gcp-project-id
FIRESTORE_COLLECTION=referral-extraction
FIRESTORE_DATABASE=referral-extraction

# Service account key file (resolved relative to this folder or the project root).
FIREBASE_SERVICE_ACCOUNT_PATH=google.json
# Or paste the SA JSON inline instead of a file:
# FIREBASE_SA_JSON={...}

# Output file for JSON mode (relative paths are written inside this folder).
EXPORT_OUTPUT_PATH=firestore_export.json

# ── Default behaviour toggles (optional) ─────────────────────────────────────
# These set what a bare `python extractor.py` does, so you don't need CLI flags.
# A CLI flag ALWAYS overrides the matching toggle (e.g. --json beats EXPORT_FORMAT=csv).
EXPORT_FORMAT=json          # json | csv   → default output format
EXPORT_INCREMENTAL=false    # true | false → csv writes only-new records
EXPORT_CLEAN_AFTER=false    # true | false → run cleanup after each export
EXPORT_WATCH=false          # true | false → run in the watch loop by default

# ── CSV / incremental tuning (optional; defaults shown) ──────────────────────
# Document field used as the incremental cursor. Records whose value is greater
# than the saved watermark are treated as "new". Default: completed_at_utc
INCREMENTAL_CURSOR_FIELD=completed_at_utc
# Prefix for generated CSVs → referrals_full_<ts>.csv / referrals_incr_<ts>.csv
CSV_FILE_PREFIX=referrals
# --watch loop interval (seconds) and --clean age threshold (minutes)
WATCH_INTERVAL_SECONDS=120
CSV_MAX_AGE_MINUTES=60
